{
  "name": "agentdevflow",
  "version": "0.1.0-beta.1",
  "description": "Configure, validate, and compile portable software-development flows for coding agents.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lorekkusu/agentdevflow.git"
  },
  "type": "module",
  "bin": {
    "agentdevflow": "dist/src/cli/private-local-cli.js"
  },
  "files": [
    "CHANGELOG.md",
    "dist/src/application/",
    "dist/src/cli/",
    "dist/src/commands/",
    "dist/src/compiler/",
    "dist/src/config/",
    "dist/src/import/",
    "dist/src/interface/",
    "dist/src/lock/",
    "dist/src/policy/",
    "dist/src/project/",
    "dist/src/renderer/",
    "dist/src/workflows/",
    "dist/src/workspace/",
    "!dist/src/commands/private-approved-init-render-service.*",
    "!dist/src/commands/private-init-command-service.*",
    "!dist/src/compiler/built-in-definitions.*",
    "!dist/src/compiler/compile-candidate.*",
    "!dist/src/config/normalize-candidate.*",
    "!dist/src/import/private-assessment.*",
    "!dist/src/interface/private-project-config-document.*",
    "!dist/src/project/private-legacy-candidate-convergence.*",
    "!dist/src/renderer/rulesync-process.*"
  ],
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "tag": "next"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:qualification": "npm run check:repository && npm run typecheck && npm run build && node scripts/run-platform-tests.mjs",
    "check:repository": "node scripts/check-repository.mjs",
    "check:v1-qualification": "npm run check:repository && npm run typecheck && npm run build && node scripts/run-v1-platform-tests.mjs",
    "experiment:recovery": "npm run build && node dist/src/experiments/recovery-strategy-comparison.js",
    "gate:policy": "npm run build && node dist/test/fixtures/policy/run.js",
    "gate:renderer": "npm run build && node dist/src/experiments/rulesync-gate1.js",
    "phase1:config": "npm run build && node dist/test/fixtures/config/run.js",
    "phase1:compiler": "npm run build && node dist/test/fixtures/compiler/run.js",
    "phase1:domain-workflows": "npm run build && node dist/test/fixtures/workflows/run.js",
    "phase1:execution-contract": "npm run build && node dist/test/fixtures/execution/run.js",
    "phase1:execution-transport": "npm run build && node dist/test/fixtures/execution/transport-run.js",
    "phase1:github-ci-evidence": "npm run build && node dist/test/fixtures/adapters/github-check-runs-run.js",
    "phase1:local-cli": "npm run build && node dist/src/cli/private-local-cli.js",
    "phase1:project-resolution": "npm run build && node dist/test/fixtures/project/run.js",
    "phase1:project-document": "npm run build && node dist/test/fixtures/project/document-run.js",
    "phase1:representation": "npm run build && node dist/test/fixtures/interface/run.js",
    "phase1:preset": "npm run build && node dist/test/fixtures/project/preset-run.js",
    "test:v1-recovery": "npm run build && node --test dist/test/renderer/private-convergent-apply.test.js dist/test/renderer/private-convergent-subprocess.test.js",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "check": "npm run check:repository && npm run typecheck && npm test"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "typescript": "7.0.2"
  },
  "dependencies": {
    "jsonc-parser": "3.3.1",
    "zod": "4.4.3"
  }
}
